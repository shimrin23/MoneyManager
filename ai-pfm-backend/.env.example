API_KEY=your_api_key_here
DATABASE_URL=your_database_connection_string_here
PORT=3000
NODE_ENV=development
BANKING_API_URL=https://api.yourbank.com
BANK_API_BASE_URL=https://api.yourbank.com
BANK_API_TOKEN=your_banking_api_token
BANK_API_TIMEOUT_MS=12000
BANK_API_MAX_RETRIES=3
BANK_API_BACKOFF_MS=500
BANK_API_FETCH_LIMIT=250
BANKING_MOCK_ENABLED=true
AI_MODEL_ENDPOINT=https://api.yourai.com/model
SYNC_INTERVAL=15
# Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=1024
GEMINI_TEMPERATURE=0.7
# Chat with Coach Configuration
CHAT_MAX_HISTORY=20
CHAT_SESSION_TIMEOUT=3600